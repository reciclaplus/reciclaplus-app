# Supabase project URL (no trailing slash)
SUPABASE_URL=https://your-project.supabase.co

# Legacy HS256 JWT secret (Supabase dashboard -> Project Settings -> API -> JWT Settings).
# Leave empty to verify tokens via the project's JWKS endpoint (asymmetric keys).
SUPABASE_JWT_SECRET=your-jwt-secret

# Direct Postgres connection (SQLAlchemy URL form).
# Supabase dashboard -> Project Settings -> Database -> Connection string.
DATABASE_URL=postgresql+psycopg://postgres:your-password@db.your-project.supabase.co:5432/postgres

# Allowed CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:3000
