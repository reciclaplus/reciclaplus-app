# Supabase project URL (no trailing slash)
SUPABASE_URL=https://your-project.supabase.co

# Legacy HS256 JWT secret (Supabase dashboard -> Project Settings -> API -> JWT Settings).
# Leave empty to verify tokens via the project's JWKS endpoint (asymmetric keys).
SUPABASE_JWT_SECRET=your-jwt-secret

# Postgres connection (SQLAlchemy URL form).
# Use the Session pooler string: Supabase dashboard -> Connect -> Session pooler.
# The direct `db.<ref>.supabase.co` host is IPv6-only and unreachable on many
# networks, so prefer the pooler. Add the `+psycopg` driver and keep port 5432;
# the username is `postgres.<project-ref>` and the host region must match the
# project (e.g. aws-1-eu-central-2).
DATABASE_URL=postgresql+psycopg://postgres.your-project-ref:your-password@aws-1-your-region.pooler.supabase.com:5432/postgres

# Allowed CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:3000
