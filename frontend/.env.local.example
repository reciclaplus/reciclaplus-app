# Supabase (development project)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# FastAPI backend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Google Maps (Maps JavaScript API enabled, restricted to localhost for dev)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# --- Testing environment ---
# Copy this block over the values above to run local dev against the shared
# "reciclapp-test" Supabase project instead of real data. Pairs with the
# matching "Testing environment" block in backend/.env.example (a local backend
# wired to the test database, still served on localhost:8000).
# NEXT_PUBLIC_SUPABASE_URL=https://your-test-project.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-test-anon-key
# NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key
# Enables the dev-only email/password login on the landing page so authed
# pages can be tested without Google OAuth. NEVER set this in production.
# NEXT_PUBLIC_ENABLE_DEV_LOGIN=true
