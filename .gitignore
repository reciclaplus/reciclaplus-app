# Environment / secrets (never commit)
.env
.env.local
.env.*.local
**/.env
**/.env.local

# OS / editor
.DS_Store
Thumbs.db

# Claude Code local state (launch.json is tracked on purpose so worktrees inherit it)
.claude/settings.local.json
.claude/scheduled_tasks.lock
.claude/worktrees/

# Service account keys (never commit)
*firebase-adminsdk*.json

# Firestore migration scripts / data dumps (one-off, not part of the app)
backend/export_firestore.py
backend/import_firestore_collections.py
backend/import_firestore_pdrs.py
backend/import_firestore_weights.py
backend/firestore_*.json
